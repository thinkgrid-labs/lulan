# Copy to .env next to production.yml and edit. Generate secrets with:
#   openssl rand -hex 32

# Public domain Caddy should obtain a certificate for.
LULAN_DOMAIN=book.example.com

# Image to run (build with `just docker-build`, or pull your registry tag).
LULAN_IMAGE=lulan-api:latest

# ---- Databases -------------------------------------------------------
# DEFAULT: external managed services — put their connection URLs here.
DATABASE_URL=postgres://user:password@your-postgres:5432/lulan
# Optional; without Redis, holds/rate limiting degrade, bookings stay correct.
REDIS_URL=redis://your-redis:6379

# BUNDLED alternative (single machine): ignore the two URLs above, set
# only this, and launch with the overlay:
#   docker compose -f production.yml -f bundled-db.yml up -d
#POSTGRES_PASSWORD=change-me

# ---- Secrets — REQUIRED ----------------------------------------------
LULAN_QUOTE_SECRET=change-me-64-hex
LULAN_BOOTSTRAP_ADMIN_KEY=llk_change-me
# First admin HUMAN (issuer|subject from your IdP) — unlocks /v1/admin/*.
#LULAN_BOOTSTRAP_ADMIN_STAFF=https://auth.example.com|user-id-of-admin

# ---- Optional: customer identity (HS256 JWT from your IdP) -----------
#LULAN_IDP_ISSUER=https://auth.example.com
#LULAN_IDP_HS256_SECRET=

# ---- Optional: operator pricing module (file under ./modules/) -------
#LULAN_PRICING_WASM=/modules/pricing.wasm

# ---- Tuning (defaults shown) ------------------------------------------
#LULAN_RATE_LIMIT=300
#LULAN_HOLD_DEFAULT_TTL_SECS=600
#LULAN_HOLD_MAX_TTL_SECS=1800
#LULAN_DB_POOL=32
#RUST_LOG=lulan_api=info,lulan_engine=info
